<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:id="@android:id/background"
    android:background="@drawable/widget_bg_dark_88"
    android:paddingTop="0dp"
    android:paddingBottom="0dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="0dp"
    android:paddingEnd="0dp">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="11sp"
            android:textColor="#ffffffff"
            android:id="@+id/widget_title"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/widget_title"
            android:layout_weight="1"
            android:fontFamily="sec"
            android:letterSpacing="0.13"/>
        <TextView
            android:textSize="11sp"
            android:textColor="#afffffff"
            android:id="@+id/plan_label"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_sample_plan"
            android:fontFamily="sec"
            android:layout_marginEnd="5dp"/>
        <ImageView
            android:id="@+id/refresh_button"
            android:visibility="gone"
            android:padding="6dp"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_oui_refresh_widget_light"
            android:contentDescription="@string/refresh"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:baselineAligned="false"
        android:layout_weight="1">
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/primary_section"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <ImageView
                android:id="@+id/primary_graphic"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:adjustViewBounds="false"
                android:contentDescription="@string/five_hour"/>
            <TextView
                android:textSize="12sp"
                android:textColor="#e8ffffff"
                android:id="@+id/primary_label"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/five_hour"
                android:fontFamily="sec"/>
            <TextView
                android:textSize="11sp"
                android:textColor="#9fffffff"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/primary_reset"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/widget_sample_primary_reset"
                android:maxLines="1"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/secondary_section"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <ImageView
                android:id="@+id/secondary_graphic"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:adjustViewBounds="false"
                android:contentDescription="@string/weekly"/>
            <TextView
                android:textSize="12sp"
                android:textColor="#e8ffffff"
                android:id="@+id/secondary_label"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/weekly"
                android:fontFamily="sec"/>
            <TextView
                android:textSize="11sp"
                android:textColor="#9fffffff"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/secondary_reset"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/widget_sample_secondary_reset"
                android:maxLines="1"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/reset_credit_row"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp">
        <TextView
            android:textSize="10sp"
            android:textColor="#9fffffff"
            android:ellipsize="end"
            android:id="@+id/reset_credit_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="2 resets · next expires in 3d"
            android:maxLines="1"
            android:layout_weight="1"/>
        <TextView
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#ffffffff"
            android:gravity="center"
            android:id="@+id/reset_credit_button"
            android:background="@drawable/widget_action_dark"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:minWidth="68dp"
            android:text="Use reset"
            android:fontFamily="sec"
            android:layout_marginStart="6dp"/>
    </LinearLayout>
    <TextView
        android:textSize="11sp"
        android:textColor="#70ffffff"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/updated_label"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/widget_sample_updated"
        android:maxLines="1"/>
</LinearLayout>
