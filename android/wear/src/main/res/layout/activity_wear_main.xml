<?xml version="1.0" encoding="utf-8"?>
<androidx.wear.widget.BoxInsetLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_boxedEdges="all">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="@dimen/wear_screen_padding_horizontal"
            android:paddingTop="@dimen/wear_screen_padding_top"
            android:paddingEnd="@dimen/wear_screen_padding_horizontal"
            android:paddingBottom="@dimen/wear_screen_padding_bottom">

            <TextView
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/app_name"
                android:textColor="@color/codex_text"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_wear_card"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="@dimen/wear_card_padding_horizontal"
                android:paddingTop="@dimen/wear_card_padding_vertical"
                android:paddingEnd="@dimen/wear_card_padding_horizontal"
                android:paddingBottom="@dimen/wear_card_padding_vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="@string/wear_five_hour"
                    android:textColor="@color/codex_secondary_text"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/five_hour_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:textColor="@color/codex_text"
                    android:textSize="42sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/weekly_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:textColor="@color/codex_secondary_text"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/account_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:textColor="@color/codex_secondary_text"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/credits_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:textColor="@color/codex_blue"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/status_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_wear_chip"
                android:gravity="center"
                android:includeFontPadding="false"
                android:minHeight="40dp"
                android:textColor="@color/codex_secondary_text"
                android:textSize="14sp" />

            <Button
                android:id="@+id/toggle_monitor_button"
                android:layout_width="match_parent"
                android:layout_height="@dimen/wear_button_height"
                android:layout_marginTop="16dp"
                android:text="@string/wear_toggle_monitor" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/wear_button_height"
                android:layout_marginTop="@dimen/wear_button_gap"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/refresh_button"
                    style="@style/OneUiWatchSecondaryButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="@string/wear_refresh"
                    android:textSize="16sp" />

                <Space
                    android:layout_width="@dimen/wear_button_gap"
                    android:layout_height="1dp" />

                <Button
                    android:id="@+id/settings_button"
                    style="@style/OneUiWatchSecondaryButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="@string/wear_settings"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.wear.widget.BoxInsetLayout>
