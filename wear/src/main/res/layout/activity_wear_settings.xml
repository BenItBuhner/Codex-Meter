<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/codex_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="22dp"
        android:paddingEnd="24dp"
        android:paddingBottom="34dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/wear_settings"
            android:textColor="@color/codex_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Display mode"
            android:textColor="@color/codex_text"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/display_mode_spinner"
            android:layout_width="match_parent"
            android:layout_height="48dp" />

        <TextView
            android:id="@+id/display_mode_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/codex_secondary_text"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Percent mode"
            android:textColor="@color/codex_text"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/percent_mode_spinner"
            android:layout_width="match_parent"
            android:layout_height="48dp" />

        <Switch
            android:id="@+id/auto_start_switch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="Auto-start at threshold"
            android:textColor="@color/codex_text" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Metric"
            android:textColor="@color/codex_text"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/metric_spinner"
            android:layout_width="match_parent"
            android:layout_height="48dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Threshold"
            android:textColor="@color/codex_text"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/threshold_spinner"
            android:layout_width="match_parent"
            android:layout_height="48dp" />

        <Switch
            android:id="@+id/monitor_switch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="Monitor active"
            android:textColor="@color/codex_text" />

        <Button
            android:id="@+id/back_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="Done" />
    </LinearLayout>
</ScrollView>
